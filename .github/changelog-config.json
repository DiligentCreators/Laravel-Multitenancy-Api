{
    "template": "## 🔖 Release: {{RELEASE}}\n\n{{CHANGELOG}}\n",
    "pr_template": "- {{TITLE}} [#{{NUMBER}}] by @{{AUTHOR}} {{ISSUE}}",
    "categories": [
        {
            "title": "🚀 Features",
            "labels": ["feature", "enhancement"]
        },
        {
            "title": "🐛 Bug Fixes",
            "labels": ["bug"]
        },
        {
            "title": "🧹 Maintenance",
            "labels": ["chore", "refactor", "cleanup"]
        },
        {
            "title": "📄 Documentation",
            "labels": ["docs"]
        }
    ],
    "sort": "mergedAt",
    "commitMode": false,
    "ignorePreReleases": true
}
