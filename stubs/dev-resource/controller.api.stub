<?php

declare(strict_types=1);

namespace {{ namespace }};

use App\Http\Controllers\Controller;
use App\Http\Requests\{{ context }}\Api\{{ version }}\{{ model }}\Store{{ model }}Request;
use App\Http\Requests\{{ context }}\Api\{{ version }}\{{ model }}\Update{{ model }}Request;
use App\Http\Resources\{{ context }}\Api\{{ version }}\{{ model }}\{{ model }}Resource;
use App\Http\Resources\{{ context }}\Api\{{ version }}\{{ model }}\List{{ model }}Resource;
use App\Models\{{ model }};
use App\Services\ApiResponseService;
use App\Services\{{ context }}\{{ model }}Service;
use Illuminate\Http\JsonResponse;
use Illuminate\Support\Facades\Gate;

class {{ class }} extends Controller
{
    public function __construct(
        ApiResponseService $api,
        private readonly {{ model }}Service ${{ modelVariable }}Service,
    ) {
        parent::__construct($api);
    }

    public function index(): JsonResponse
    {
        Gate::authorize('viewAny', {{ model }}::class);

        ${{ modelPlural }} = $this->{{ modelVariable }}Service->paginate(
            request(),
            $this->perPage(request()),
        );

        return $this->api->success(
            '{{ modelPlural }} retrieved successfully',
            List{{ model }}Resource::collection(${{ modelPlural }}),
        );
    }

    public function store(Store{{ model }}Request $request): JsonResponse
    {
        Gate::authorize('create', {{ model }}::class);

        ${{ modelVariable }} = $this->{{ modelVariable }}Service->create($request->validated());

        return $this->api->success(
            '{{ model }} has been created successfully',
            new {{ model }}Resource(${{ modelVariable }}),
            201,
        );
    }

    public function show({{ model }} ${{ modelVariable }}): JsonResponse
    {
        Gate::authorize('view', ${{ modelVariable }});

        if (${{ modelVariable }}->trashed()) {
            return $this->api->notFound('{{ model }} has been deleted.');
        }

        return $this->api->success(
            '{{ model }} retrieved successfully',
            new {{ model }}Resource(${{ modelVariable }}),
        );
    }

    public function update(Update{{ model }}Request $request, {{ model }} ${{ modelVariable }}): JsonResponse
    {
        Gate::authorize('update', ${{ modelVariable }});

        if (${{ modelVariable }}->trashed()) {
            return $this->api->notFound('Cannot update a deleted {{ modelVariable }}.');
        }

        $this->{{ modelVariable }}Service->update(${{ modelVariable }}, $request->validated());

        return $this->api->success(
            '{{ model }} has been updated successfully',
            new {{ model }}Resource(${{ modelVariable }}),
        );
    }

    public function destroy({{ model }} ${{ modelVariable }}): JsonResponse
    {
        Gate::authorize('delete', ${{ modelVariable }});

        if (${{ modelVariable }}->trashed()) {
            return $this->api->notFound('{{ model }} is already deleted.');
        }

        ${{ modelVariable }}->delete();

        return $this->api->success(
            '{{ model }} has been deleted successfully',
            null,
            200,
        );
    }

    public function restore({{ model }} ${{ modelVariable }}): JsonResponse
    {
        Gate::authorize('restore', ${{ modelVariable }});

        if (! ${{ modelVariable }}->trashed()) {
            return $this->api->notFound('{{ model }} is not deleted.');
        }

        ${{ modelVariable }}->restore();

        return $this->api->success(
            '{{ model }} has been restored successfully',
            new {{ model }}Resource(${{ modelVariable }}),
        );
    }

    public function forceDelete({{ model }} ${{ modelVariable }}): JsonResponse
    {
        Gate::authorize('forceDelete', ${{ modelVariable }});

        if (! ${{ modelVariable }}->trashed()) {
            return $this->api->error('{{ model }} must be deleted before force deleting.', 400);
        }

        ${{ modelVariable }}->forceDelete();

        return $this->api->success(
            '{{ model }} has been force deleted successfully',
            null,
            200,
        );
    }
}
