<?php

declare(strict_types=1);

namespace {{ namespace }};

use App\Http\Controllers\Controller;
use App\Models\{{ model }};
use App\Http\Requests\{{ context }}\Api\{{ version }}{{ pathSegment }}\Store{{ model }}Request;
use App\Http\Requests\{{ context }}\Api\{{ version }}{{ pathSegment }}\Update{{ model }}Request;
use App\Http\Resources\{{ context }}\Api\{{ version }}{{ pathSegment }}\{{ model }}Resource;
use App\Http\Resources\{{ context }}\Api\{{ version }}{{ pathSegment }}\List{{ model }}Resource;
use Illuminate\Http\JsonResponse;
use Illuminate\Support\Facades\Gate;

class {{ class }} extends Controller
{
    public function index(): JsonResponse
    {
        Gate::authorize('viewAny', {{ model }}::class);

        return $this->api->success(
            __('crud.index', ['resource' => '{{ model }}']),
            List{{ model }}Resource::collection({{ model }}::paginate()),
        );
    }

    public function store(Store{{ model }}Request $request): JsonResponse
    {
        Gate::authorize('create', {{ model }}::class);

        ${{ modelVariable }} = {{ model }}::create($request->validated());

        return $this->api->success(
            __('crud.store', ['resource' => '{{ model }}']),
            new {{ model }}Resource(${{ modelVariable }}),
            201,
        );
    }

    public function show({{ model }} ${{ modelVariable }}): JsonResponse
    {
        Gate::authorize('view', ${{ modelVariable }});

        if (${{ modelVariable }}->trashed()) {
            return $this->api->notFound(__('{{ model }} has been deleted.'));
        }

        return $this->api->success(
            __('crud.show', ['resource' => '{{ model }}']),
            new {{ model }}Resource(${{ modelVariable }}),
        );
    }

    public function update(Update{{ model }}Request $request, {{ model }} ${{ modelVariable }}): JsonResponse
    {
        Gate::authorize('update', ${{ modelVariable }});

        if (${{ modelVariable }}->trashed()) {
            return $this->api->notFound(__('Cannot update a deleted {{ modelVariable }}.'));
        }

        ${{ modelVariable }}->update($request->validated());

        return $this->api->success(
            __('crud.update', ['resource' => '{{ model }}']),
            new {{ model }}Resource(${{ modelVariable }}),
        );
    }

    public function destroy({{ model }} ${{ modelVariable }}): JsonResponse
    {
        Gate::authorize('delete', ${{ modelVariable }});

        if (${{ modelVariable }}->trashed()) {
            return $this->api->notFound(__('{{ model }} is already deleted.'));
        }

        ${{ modelVariable }}->delete();

        return $this->api->success(
            __('crud.destroy', ['resource' => '{{ model }}']),
            null,
            204,
        );
    }

    public function restore({{ model }} ${{ modelVariable }}): JsonResponse
    {
        Gate::authorize('restore', ${{ modelVariable }});

        if (! ${{ modelVariable }}->trashed()) {
            return $this->api->notFound(__('{{ model }} is not deleted.'));
        }

        ${{ modelVariable }}->restore();

        return $this->api->success(
            __('crud.restore', ['resource' => '{{ model }}']),
            new {{ model }}Resource(${{ modelVariable }}),
        );
    }

    public function forceDelete({{ model }} ${{ modelVariable }}): JsonResponse
    {
        Gate::authorize('forceDelete', ${{ modelVariable }});

        if (! ${{ modelVariable }}->trashed()) {
            return $this->api->error(__('{{ model }} must be deleted before force deleting.'), 400);
        }

        ${{ modelVariable }}->forceDelete();

        return $this->api->success(
            __('crud.force_delete', ['resource' => '{{ model }}']),
            null,
            204,
        );
    }
}
